    "@nuxt/fonts": "0.11.2",
    "@nuxt/icon": "1.12.0",
    "@nuxt/image": "1.10.0",
    "@nuxt/scripts": "0.11.6",
    "@nuxt/test-utils": "3.18.0",
    "@prisma/client": "^6.9.0",
    "@sidebase/nuxt-auth": "^0.6.7",
    "@unhead/vue": "^2.0.10",
    "@vueuse/nuxt": "^13.3.0",
