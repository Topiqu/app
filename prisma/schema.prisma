//////////////////////////////////////////////////////////////////////////////////////////////

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ArticleStatus {
  draft
  published
}

enum UserRole {
  admin
  superadmin
  reader
}

enum GenerationFrequency {
  NONE
  DAILY
  WEEKLY
}

enum ClientPlan {
  BASIC
  PRO
  PREMIUM
  CUSTOM
}

enum ReactionType {
  LIKE
  DISLIKE
}

model Article {
  id          String        @id() @default(uuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime?     @updatedAt()
  deletedAt   DateTime?
  slug        String        @unique()
  title       String
  content     String
  imageUrl    String?
  status      ArticleStatus @default(draft)
  publishedAt DateTime?
  views       Int           @default(0)
  readingTime Int?
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  tags        ArticleTag[]
  comments    Comment[]
}

model Tag {
  id        String       @id() @default(uuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime?    @updatedAt()
  deletedAt DateTime?
  slug      String       @unique()
  name      String       @unique()
  articles  ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model User {
  id            String            @id() @default(uuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime?         @updatedAt()
  deletedAt     DateTime?
  username      String            @unique()
  email         String            @unique()
  password      String?
  bio           String?
  role          UserRole          @default(admin)
  articles      Article[]
  clientSite    ClientSite?       @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  clientSiteId  String?
  comments      Comment[]
  verification  VerificationCode?
  reactions     CommentReaction[]
  emailVerified Boolean           @default(false)
}

model ClientSite {
  id                  String              @id() @default(uuid())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime?           @updatedAt()
  deletedAt           DateTime?
  name                String
  subdomain           String              @unique()
  plan                ClientPlan          @default(BASIC)
  generationFrequency GenerationFrequency @default(NONE)
  tokenLimit          Int?                @default(0)
  tokenRemaining      Int?                @default(0)
  users               User[]
  focus               String?
  keywords            Json?
}

model Comment {
  id        String            @id() @default(uuid())
  createdAt DateTime          @default(now())
  updatedAt DateTime?         @updatedAt()
  deletedAt DateTime?
  content   String
  article   Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  user      User              @relation(fields: [userId], references: [id])
  userId    String
  parent    Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  replies   Comment[]         @relation("CommentReplies")
  reactions CommentReaction[]
}

model CommentReaction {
  userId    String
  commentId String
  type      ReactionType
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model VerificationCode {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  code      String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @unique()
  expiresAt DateTime
}
