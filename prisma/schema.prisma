//////////////////////////////////////////////////////////////////////////////////////////////
// DO NOT MODIFY THIS FILE                                                                  //
// This file is automatically generated by ZenStack CLI and should not be manually updated. //
//////////////////////////////////////////////////////////////////////////////////////////////

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ThemeOption {
  light
  dark
}

enum UserRole {
  admin
  superadmin
  reader
  ai
}

enum Language {
  cs
  en
}

enum Theme {
  blue
  green
  red
  purple
  orange
  teal
  yellow
  pink
  indigo
  gray
  lime
  sky
  amber
  cyan
  violet
}

enum GenerationFrequency {
  NONE
  DAILY
  WEEKLY
}

enum FeatureCodes {
  AI
  CRONS
  SENTIMENT
  ARTICLE_CRONS
}

enum AIInvolvement {
  NONE
  ASSIST
  FULL
}

enum ClientPlan {
  BASIC
  PRO
  PREMIUM
  CUSTOM
}

enum BillingPlans {
  MONTHLY
  ANNUAL
  PERMANENT
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  MENTION
  ARTICLE_PUBLISHED
  SYSTEM
}

enum SocialPlatform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  OTHER
}

enum SharePlatform {
  TWITTER
  FACEBOOK
  LINKEDIN
  EMAIL
  OTHER
}

enum SentimentStatus {
  PENDING
  SKIPPED
  PROCESSED
  ERROR
}

enum PublishMode {
  HitL
  FullAuto
}

enum ContentTaskStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum DraftStatus {
  DRAFT
  AWAITING_APPROVAL
  APPROVED
  PUBLISHING
  REJECTED
  PUBLISHED
  FAILED
}

enum ApprovalDecision {
  APPROVE
  REJECT
}

model ArticleDraft {
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  id           String     @id() @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt()
  deletedAt    DateTime?
  title        String
  excerpt      String?
  content      String
  imageUrl     String?
  clientSiteId String
  clientSite   ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model Article {
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  id               String            @id() @default(uuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @updatedAt()
  deletedAt        DateTime?
  slug             String
  title            String
  excerpt          String?
  content          String
  imageUrl         String?
  status           ArticleStatus     @default(draft)
  clientSiteId     String
  clientSite       ClientSite        @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  views            Int               @default(0)
  shared           Int               @default(0)
  aiInvolvement    AIInvolvement     @default(NONE)
  readingTime      Int?
  totalWords       Int?
  savedAmount      Float             @default(0.0)
  savedTimeMinutes Int               @default(0)
  publishedAt      DateTime?
  articleSeriesId  String?
  articleSeries    ArticleSeries?    @relation(fields: [articleSeriesId], references: [id], onDelete: SetNull)
  seriesOrder      Int?              @default(0)
  releaseAt        DateTime?
  allowedComments  Boolean           @default(true)
  tags             ArticleTag[]
  comments         Comment[]
  reactions        ArticleReaction[]
  shares           ArticleShare[]
  feedbacks        ArticleFeedback[]
  pollResults      PollResult[]
  polls            Poll[]
  notifications    Notification[]    @relation("ArticleNotifications")
  sources          String[]
  prompt           String?

  @@unique([slug, clientSiteId])
  @@index([title, excerpt, clientSiteId, articleSeriesId, seriesOrder])
}

model ArticleSeries {
  id           String     @id() @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt()
  deletedAt    DateTime?
  name         String
  slug         String
  description  String?
  imageUrl     String?
  clientSiteId String
  clientSite   ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles     Article[]

  @@unique([slug, clientSiteId])
}

model ArticleShare {
  id        String        @id() @default(uuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime?     @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform  SharePlatform
}

model Tag {
  id           String       @id() @default(uuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?    @updatedAt()
  deletedAt    DateTime?
  slug         String
  name         String
  clientSiteId String?
  clientSite   ClientSite?  @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles     ArticleTag[]
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model ArticleFeedback {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  isHelpful Boolean
  reason    String?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?

  @@unique([articleId, userId, sessionId])
}

model ArticleReaction {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?

  @@unique([articleId, userId, sessionId])
}

model Log {
  id           String      @id() @default(uuid())
  action       String
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade, name: "LogToUser")
  clientSiteId String?
  clientSite   ClientSite? @relation(fields: [clientSiteId], references: [id], onDelete: Cascade, name: "LogToClientSite")
  metadata     Json?
  createdAt    DateTime    @default(now())
  ip           String?
  previousHash String?
  hash         String
}

model User {
  id                            String            @id() @default(uuid())
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime?         @updatedAt()
  deletedAt                     DateTime?
  username                      String            @unique()
  email                         String            @unique()
  password                      String?
  bio                           String?
  role                          UserRole          @default(reader)
  avatarUrl                     String?
  verification                  VerificationCode?
  totpSecret                    String?
  totpTempSecret                String?
  onboardingLoginToken          String?
  onboardingLoginTokenExpiresAt DateTime?
  emailVerified                 Boolean           @default(false)
  allowNotifs                   Boolean           @default(true)
  allowEmail                    Boolean           @default(true)
  lastLogin                     DateTime?         @default(now())
  language                      Language          @default(en)
  sessions                      Session[]         @relation("UserSessions")
  clientSiteId                  String?
  theme                         ThemeOption       @default(light)
  clientSite                    ClientSite?       @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles                      Article[]
  articleDrafts                 ArticleDraft[]
  comments                      Comment[]
  notifications                 Notification[]
  reactions                     CommentReaction[]
  feedbacks                     ArticleFeedback[]
  emojiReactions                EmojiReaction[]
  articleReactions              ArticleReaction[]
  followers                     Follow[]          @relation("Follower")
  following                     Follow[]          @relation("Followed")
  bans                          UserBan[]         @relation("BannedUser")
  bansIssued                    UserBan[]         @relation("BannedBy")
  logs                          Log[]             @relation("LogToUser")
  approvals                     Approval[]

  @@index([username, email, role, language, allowNotifs])
}

model Session {
  id         String    @id() @default(uuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt()
  deletedAt  DateTime?
  ip         String?
  userAgent  String?
  device     String?
  os         String?
  browser    String?
  city       String?
  region     String?
  country    String?
  lastUsedAt DateTime  @default(now())
  revoked    Boolean   @default(false)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserSessions")

  @@index([userId, lastUsedAt])
}

model Follow {
  followerId String
  followedId String
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed   User     @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, followedId])
}

model Social {
  id           String         @id() @default(uuid())
  platform     SocialPlatform
  url          String
  clientSiteId String
  clientSite   ClientSite     @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
}

model ClientSite {
  id                   String              @id() @default(uuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime?           @updatedAt()
  deletedAt            DateTime?
  name                 String              @unique()
  domain               String              @unique()
  domainVerified       Boolean             @default(false)
  plan                 ClientPlan          @default(BASIC)
  focus                String?
  description          String?
  logoUrl              String?
  generationFrequency  GenerationFrequency @default(NONE)
  tokenLimit           Int?                @default(0)
  tokenRemaining       Int?                @default(0)
  totalUsage           Int?                @default(0)
  autoRelease          Boolean             @default(false)
  keywords             Json?
  audience             String?
  lastGeneratedAt      DateTime?
  humanHourlyRate      Int                 @default(1400)
  humanWordsPerHour    Int                 @default(400)
  gtagId               String?
  apiKey               String?
  gamNetworkCode       String?
  allowAds             Boolean             @default(false)
  allowGtag            Boolean?
  allowShapes          Boolean             @default(false)
  aiToneOfVoice        String?
  aiControversyLevel   String?
  communityInsight     Json?
  insightUpdatedAt     DateTime?
  billingPlan          BillingPlans        @default(MONTHLY)
  firstPaidAt          DateTime?
  nextBillingAt        DateTime?
  lastInvoicedAt       DateTime?
  monthlyPayment       Int?                @default(0)
  annualPayment        Int?                @default(0)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  enableAi             Boolean             @default(false)
  enableCron           Boolean             @default(false)
  enableSentiment      Boolean             @default(false)
  currency             String?             @default("USD")
  lastPaidAt           DateTime?           @default(now())
  lastTokenRefilled    DateTime?           @default(now())
  language             Language            @default(en)
  theme                Theme               @default(blue)
  users                User[]
  tags                 Tag[]
  articles             Article[]
  articleSeries        ArticleSeries[]
  articleDrafts        ArticleDraft[]
  emojis               Emoji[]
  userBans             UserBan[]
  socials              Social[]
  logs                 Log[]               @relation("LogToClientSite")
  features             ClientFeature[]
  linkedinCompanies    LinkedinCompany[]

  @@index([domain, name, plan, billingPlan, enableAi, enableCron, enableSentiment])
}

model Feature {
  id             String          @id() @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt()
  deletedAt      DateTime?
  code           FeatureCodes    @unique()
  name           String
  priceMonthly   Int
  priceAnnual    Int?
  tier           String?
  clientFeatures ClientFeature[]
}

model ClientFeature {
  id                 String     @id() @default(uuid())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime?  @updatedAt()
  deletedAt          DateTime?
  clientSiteId       String
  featureId          String
  feature            Feature    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  activatedAt        DateTime   @default(now())
  deactivatedAt      DateTime?
  billingLockedUntil DateTime
  isActive           Boolean    @default(true)
  clientSite         ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)

  @@unique([clientSiteId, featureId])
  @@index([clientSiteId])
  @@index([billingLockedUntil])
}

model PollResult {
  id        String     @id() @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime?  @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String?
  sessionId String?

  @@unique([pollId, userId])
  @@unique([pollId, sessionId])
  @@index([pollId])
  @@index([optionId])
  @@index([articleId])
}

model Poll {
  id        String       @id() @default(uuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime?    @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  question  String
  order     Int          @default(0)
  options   PollOption[]
  results   PollResult[]

  @@index([articleId])
}

model PollOption {
  id        String       @id() @default(uuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime?    @updatedAt()
  deletedAt DateTime?
  pollId    String
  poll      Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label     String
  order     Int          @default(0)
  results   PollResult[]

  @@index([pollId])
}

model UserBan {
  id           String     @id() @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt()
  deletedAt    DateTime?
  userId       String
  user         User       @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  clientSiteId String
  clientSite   ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  reason       String?
  bannedById   String
  bannedBy     User       @relation("BannedBy", fields: [bannedById], references: [id], onDelete: Cascade)
  expiresAt    DateTime?
}

model Comment {
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  id              String            @id() @default(uuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?         @updatedAt()
  deletedAt       DateTime?
  content         String
  gifUrl          String?
  articleId       String
  article         Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  reactions       CommentReaction[]
  emojiReactions  EmojiReaction[]
  replies         Comment[]         @relation("CommentReplies")
  sentiment       Json?
  sentimentStatus SentimentStatus   @default(PENDING)

  @@index([sentimentStatus])
}

model CommentReaction {
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  type      ReactionType
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model Emoji {
  id             String          @id() @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt()
  deletedAt      DateTime?
  shortcode      String
  imageUrl       String
  clientSiteId   String
  clientSite     ClientSite      @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  emojiReactions EmojiReaction[]

  @@unique([shortcode, clientSiteId])
}

model EmojiReaction {
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  emojiId   String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  emoji     Emoji   @relation(fields: [emojiId], references: [id], onDelete: Cascade)

  @@id([userId, commentId, emojiId])
}

model VerificationCode {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  code      String
  expiresAt DateTime

  @@unique([userId])
}

model Notification {
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  id        String           @id() @default(uuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime?        @updatedAt()
  deletedAt DateTime?
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType
  articleId String?
  link      String?
  article   Article?         @relation("ArticleNotifications", fields: [articleId], references: [id], onDelete: Cascade)
}

model LinkedinCompany {
  id             String        @id() @default(uuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime?     @updatedAt()
  deletedAt      DateTime?
  name           String
  linkedinOrgId  String        @unique()
  type           String        @default("personal")
  mode           PublishMode   @default(HitL)
  timezone       String        @default("UTC")
  cadence        String        @default("daily")
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  clientSiteId   String
  clientSite     ClientSite    @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  brandProfile   BrandProfile?
  contentTasks   ContentTask[]
}

model BrandProfile {
  id        String          @id() @default(uuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime?       @updatedAt()
  deletedAt DateTime?
  companyId String          @unique()
  company   LinkedinCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tone      String?
  audience  String?
  doList    String[]
  dontList  String[]
  examples  String[]
}

model ContentTask {
  id        String            @id() @default(uuid())
  createdAt DateTime          @default(now())
  updatedAt DateTime?         @updatedAt()
  deletedAt DateTime?
  companyId String
  company   LinkedinCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  topic     String
  dueAt     DateTime
  status    ContentTaskStatus @default(PENDING)
  drafts    DraftPost[]
}

model DraftPost {
  id          String         @id() @default(uuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime?      @updatedAt()
  deletedAt   DateTime?
  taskId      String
  task        ContentTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text        String
  score       Int            @default(0)
  policyFlags Json?
  status      DraftStatus    @default(DRAFT)
  approvals   Approval[]
  published   PublishedPost?
}

model Approval {
  id         String           @id() @default(uuid())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime?        @updatedAt()
  deletedAt  DateTime?
  draftId    String
  draft      DraftPost        @relation(fields: [draftId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User             @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  decision   ApprovalDecision
  notes      String?
  decidedAt  DateTime         @default(now())
}

model PublishedPost {
  id             String       @id() @default(uuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime?    @updatedAt()
  deletedAt      DateTime?
  draftId        String       @unique()
  draft          DraftPost    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  linkedinPostId String       @unique()
  publishedAt    DateTime     @default(now())
  metrics        PostMetric[]
}

model PostMetric {
  id              String        @id() @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime?     @updatedAt()
  deletedAt       DateTime?
  publishedPostId String
  publishedPost   PublishedPost @relation(fields: [publishedPostId], references: [id], onDelete: Cascade)
  impressions     Int           @default(0)
  clicks          Int           @default(0)
  reactions       Int           @default(0)
  comments        Int           @default(0)
  capturedAt      DateTime      @default(now())
}
