// This file is automatically generated by ZenStack CLI and should not be manually updated. //
//////////////////////////////////////////////////////////////////////////////////////////////

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ArticleStatus {
  draft
  published
}

enum UserRole {
  admin
  superadmin
  reader
}

enum GenerationFrequency {
  NONE
  DAILY
  WEEKLY
}

enum ClientPlan {
  BASIC
  PRO
  PREMIUM
  CUSTOM
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  MENTION
  ARTICLE_PUBLISHED
  SYSTEM
}

model Article {
  id            String         @id() @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime?      @updatedAt()
  deletedAt     DateTime?
  slug          String         @unique()
  title         String
  content       String
  imageUrl      String?
  status        ArticleStatus  @default(draft)
  publishedAt   DateTime?
  views         Int            @default(0)
  readingTime   Int?
  user          User           @relation(fields: [userId], references: [id])
  userId        String
  tags          ArticleTag[]
  comments      Comment[]
  notifications Notification[] @relation("ArticleNotifications")
}

model Tag {
  id           String       @id() @default(uuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?    @updatedAt()
  deletedAt    DateTime?
  slug         String
  name         String
  clientSiteId String?
  clientSite   ClientSite?  @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles     ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model User {
  id            String            @id() @default(uuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime?         @updatedAt()
  deletedAt     DateTime?
  username      String            @unique()
  email         String            @unique()
  password      String?
  bio           String?
  role          UserRole          @default(admin)
  articles      Article[]
  clientSite    ClientSite?       @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  clientSiteId  String?
  comments      Comment[]
  verification  VerificationCode?
  reactions     CommentReaction[]
  emailVerified Boolean           @default(false)
  notifications Notification[]    @relation("UserNotifications")
  avatarUrl     String?
  allowNotifs   Boolean           @default(true)
  lastLogin     DateTime?         @default(now())
}

model ClientSite {
  id                  String              @id() @default(uuid())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime?           @updatedAt()
  deletedAt           DateTime?
  name                String
  subdomain           String              @unique()
  plan                ClientPlan          @default(BASIC)
  generationFrequency GenerationFrequency @default(NONE)
  tokenLimit          Int?                @default(0)
  tokenRemaining      Int?                @default(0)
  users               User[]
  tags                Tag[]
  focus               String?
  keywords            Json?
}

model Comment {
  id        String            @id() @default(uuid())
  createdAt DateTime          @default(now())
  updatedAt DateTime?         @updatedAt()
  deletedAt DateTime?
  content   String
  article   Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  user      User              @relation(fields: [userId], references: [id])
  userId    String
  parent    Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  replies   Comment[]         @relation("CommentReplies")
  reactions CommentReaction[]
}

model CommentReaction {
  userId    String
  commentId String
  type      ReactionType
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model VerificationCode {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  code      String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @unique()
  expiresAt DateTime
}

model Notification {
  id        String           @id() @default(uuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime?        @updatedAt()
  deletedAt DateTime?
  message   String
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  article   Article?         @relation("ArticleNotifications", fields: [articleId], references: [id], onDelete: Cascade)
  articleId String?
  type      NotificationType
  isRead    Boolean          @default(false)
}
