datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ArticleStatus {
  draft
  published
}

enum UserRole {
  admin
  superadmin
  reader
}

enum GenerationFrequency {
  NONE
  DAILY
  WEEKLY
}

enum ClientPlan {
  BASIC
  PRO
  PREMIUM
  CUSTOM
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  MENTION
  ARTICLE_PUBLISHED
  SYSTEM
}

model Article {
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  id            String            @id() @default(uuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime?         @updatedAt()
  deletedAt     DateTime?
  slug          String            @unique()
  title         String
  content       String
  imageUrl      String?
  status        ArticleStatus     @default(draft)
  clientSiteId  String
  clientSite    ClientSite        @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  views         Int               @default(0)
  readingTime   Int?
  publishedAt   DateTime?
  tags          ArticleTag[]
  comments      Comment[]
  reactions     ArticleReaction[]
  notifications Notification[]    @relation("ArticleNotifications")
}

model Tag {
  id           String       @id() @default(uuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?    @updatedAt()
  deletedAt    DateTime?
  slug         String
  name         String
  clientSiteId String?
  clientSite   ClientSite?  @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles     ArticleTag[]
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model User {
  id               String            @id() @default(uuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @updatedAt()
  deletedAt        DateTime?
  username         String            @unique()
  email            String            @unique()
  password         String?
  bio              String?
  role             UserRole          @default(reader)
  avatarUrl        String?
  verification     VerificationCode?
  emailVerified    Boolean           @default(false)
  allowNotifs      Boolean           @default(true)
  lastLogin        DateTime?         @default(now())
  clientSiteId     String?
  clientSite       ClientSite?       @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles         Article[]
  comments         Comment[]
  notifications    Notification[]
  reactions        CommentReaction[]
  emojiReactions   EmojiReaction[]
  articleReactions ArticleReaction[]
}

model ClientSite {
  id                  String              @id() @default(uuid())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime?           @updatedAt()
  deletedAt           DateTime?
  name                String
  subdomain           String              @unique()
  plan                ClientPlan          @default(BASIC)
  focus               String?
  generationFrequency GenerationFrequency @default(NONE)
  tokenLimit          Int?                @default(0)
  tokenRemaining      Int?                @default(0)
  keywords            Json?
  users               User[]
  tags                Tag[]
  articles            Article[]
  emojis              Emoji[]
}

model Comment {
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  id             String            @id() @default(uuid())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime?         @updatedAt()
  deletedAt      DateTime?
  content        String
  articleId      String
  article        Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  reactions      CommentReaction[]
  emojiReactions EmojiReaction[]
  replies        Comment[]         @relation("CommentReplies")
}

model CommentReaction {
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  type      ReactionType
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model Emoji {
  id             String          @id() @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt()
  deletedAt      DateTime?
  shortcode      String          @unique()
  imageUrl       String
  clientSiteId   String
  clientSite     ClientSite      @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  emojiReactions EmojiReaction[]
}

model EmojiReaction {
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  emojiId   String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  emoji     Emoji   @relation(fields: [emojiId], references: [id], onDelete: Cascade)

  @@id([userId, commentId, emojiId])
}

model ArticleReaction {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?

  @@unique([articleId, userId, sessionId])
}

model VerificationCode {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  code      String
  expiresAt DateTime

  @@unique([userId])
}

model Notification {
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  id        String           @id() @default(uuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime?        @updatedAt()
  deletedAt DateTime?
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType
  articleId String?
  article   Article?         @relation("ArticleNotifications", fields: [articleId], references: [id], onDelete: Cascade)
}
