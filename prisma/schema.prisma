datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ThemeOption {
  light
  dark
}

enum UserRole {
  admin
  superadmin
  reader
  ai
}

enum Language {
  cs
  en
}

enum Theme {
  blue
  green
  red
  purple
  orange
  teal
  yellow
  pink
  indigo
  gray
  lime
  sky
  amber
  cyan
  violet
}

enum GenerationFrequency {
  NONE
  DAILY
  WEEKLY
}

enum ClientPlan {
  BASIC
  PRO
  PREMIUM
  CUSTOM
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  MENTION
  ARTICLE_PUBLISHED
  SYSTEM
}

enum SocialPlatform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  OTHER
}

enum SharePlatform {
  TWITTER
  FACEBOOK
  LINKEDIN
  EMAIL
  OTHER
}

enum SentimentStatus {
  PENDING
  SKIPPED
  PROCESSED
  ERROR
}

model ArticleDraft {
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  id           String     @id() @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt()
  deletedAt    DateTime?
  title        String
  excerpt      String?
  content      String
  imageUrl     String?
  clientSiteId String
  clientSite   ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model Article {
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  id              String            @id() @default(uuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?         @updatedAt()
  deletedAt       DateTime?
  slug            String            @unique()
  title           String
  excerpt         String?
  content         String
  imageUrl        String?
  status          ArticleStatus     @default(draft)
  clientSiteId    String
  clientSite      ClientSite        @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  views           Int               @default(0)
  shared          Int               @default(0)
  readingTime     Int?
  publishedAt     DateTime?
  releaseAt       DateTime?
  allowedComments Boolean           @default(true)
  tags            ArticleTag[]
  comments        Comment[]
  reactions       ArticleReaction[]
  shares          ArticleShare[]
  pollResults     PollResult[]
  notifications   Notification[]    @relation("ArticleNotifications")
  sources         String[]
  prompt          String?

  @@index([title])
  @@index([excerpt])
}

model ArticleShare {
  id        String        @id() @default(uuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime?     @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform  SharePlatform
}

model Tag {
  id           String       @id() @default(uuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?    @updatedAt()
  deletedAt    DateTime?
  slug         String
  name         String
  clientSiteId String?
  clientSite   ClientSite?  @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles     ArticleTag[]
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Log {
  id           String      @id() @default(uuid())
  action       String
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade, name: "LogToUser")
  clientSiteId String?
  clientSite   ClientSite? @relation(fields: [clientSiteId], references: [id], onDelete: Cascade, name: "LogToClientSite")
  metadata     Json?
  createdAt    DateTime    @default(now())
  ip           String?
  previousHash String?
  hash         String
}

model User {
  id               String            @id() @default(uuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @updatedAt()
  deletedAt        DateTime?
  username         String            @unique()
  email            String            @unique()
  password         String?
  bio              String?
  role             UserRole          @default(reader)
  avatarUrl        String?
  verification     VerificationCode?
  totpSecret       String?
  totpTempSecret   String?
  emailVerified    Boolean           @default(false)
  allowNotifs      Boolean           @default(true)
  allowEmail       Boolean           @default(true)
  lastLogin        DateTime?         @default(now())
  language         Language          @default(en)
  sessions         Session[]         @relation("UserSessions")
  clientSiteId     String?
  theme            ThemeOption       @default(light)
  clientSite       ClientSite?       @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  articles         Article[]
  articleDrafts    ArticleDraft[]
  comments         Comment[]
  notifications    Notification[]
  reactions        CommentReaction[]
  emojiReactions   EmojiReaction[]
  articleReactions ArticleReaction[]
  followers        Follow[]          @relation("Follower")
  following        Follow[]          @relation("Followed")
  bans             UserBan[]         @relation("BannedUser")
  bansIssued       UserBan[]         @relation("BannedBy")
  logs             Log[]             @relation("LogToUser")
}

model Session {
  id         String    @id() @default(uuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt()
  deletedAt  DateTime?
  ip         String?
  userAgent  String?
  device     String?
  os         String?
  browser    String?
  city       String?
  region     String?
  country    String?
  lastUsedAt DateTime  @default(now())
  revoked    Boolean   @default(false)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserSessions")

  @@index([userId, lastUsedAt])
}

model Follow {
  followerId String
  followedId String
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed   User     @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, followedId])
}

model Social {
  id           String         @id() @default(uuid())
  platform     SocialPlatform
  url          String
  clientSiteId String
  clientSite   ClientSite     @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
}

model ClientSite {
  id                  String              @id() @default(uuid())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime?           @updatedAt()
  deletedAt           DateTime?
  name                String              @unique()
  subdomain           String              @unique()
  plan                ClientPlan          @default(BASIC)
  focus               String?
  description         String?
  logoUrl             String?
  generationFrequency GenerationFrequency @default(NONE)
  tokenLimit          Int?                @default(0)
  tokenRemaining      Int?                @default(0)
  keywords            Json?
  audience            String?
  lastGeneratedAt     DateTime?
  gtagId              String?
  gamNetworkCode      String?
  allowAds            Boolean             @default(false)
  allowGtag           Boolean?
  allowShapes         Boolean             @default(false)
  language            Language            @default(en)
  theme               Theme               @default(blue)
  users               User[]
  tags                Tag[]
  articles            Article[]
  articleDrafts       ArticleDraft[]
  emojis              Emoji[]
  userBans            UserBan[]
  socials             Social[]
  logs                Log[]               @relation("LogToClientSite")
}

model PollResult {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  articleId String
  userId    String?
  pollId    String?
  sessionId String?
  response  String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, response])
}

model UserBan {
  id           String     @id() @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt()
  deletedAt    DateTime?
  userId       String
  user         User       @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  clientSiteId String
  clientSite   ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  reason       String?
  bannedById   String
  bannedBy     User       @relation("BannedBy", fields: [bannedById], references: [id], onDelete: Cascade)
  expiresAt    DateTime?
}

model Comment {
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  id              String            @id() @default(uuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?         @updatedAt()
  deletedAt       DateTime?
  content         String
  gifUrl          String?
  articleId       String
  article         Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  reactions       CommentReaction[]
  emojiReactions  EmojiReaction[]
  replies         Comment[]         @relation("CommentReplies")
  sentiment       Json?
  sentimentStatus SentimentStatus   @default(PENDING)

  @@index([sentimentStatus])
}

model CommentReaction {
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  type      ReactionType
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model Emoji {
  id             String          @id() @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt()
  deletedAt      DateTime?
  shortcode      String          @unique()
  imageUrl       String
  clientSiteId   String
  clientSite     ClientSite      @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  emojiReactions EmojiReaction[]
}

model EmojiReaction {
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  emojiId   String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  emoji     Emoji   @relation(fields: [emojiId], references: [id], onDelete: Cascade)

  @@id([userId, commentId, emojiId])
}

model ArticleReaction {
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  articleId String
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?

  @@unique([articleId, userId, sessionId])
}

model VerificationCode {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  id        String    @id() @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  deletedAt DateTime?
  code      String
  expiresAt DateTime

  @@unique([userId])
}

model Notification {
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  id        String           @id() @default(uuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime?        @updatedAt()
  deletedAt DateTime?
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType
  articleId String?
  link      String?
  article   Article?         @relation("ArticleNotifications", fields: [articleId], references: [id], onDelete: Cascade)
}
